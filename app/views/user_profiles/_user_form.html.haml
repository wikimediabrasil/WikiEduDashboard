= javascript_include_tag '/assets/javascripts/jquery.min.js'
= hot_javascript_tag 'editable'
#profile
  = form_for(@user_profile, url: update_user_profile_path, method: :post, html: { class: 'rails_editable', multipart: true }) do |f|
    = hidden_field_tag :username, @user.username
    #disclaimer
      .module
        .module__data
          = t("user_profiles.disclaimer")

    #profile_left
      .rails_editable-field
        #user_image
          - if @user.profile_image
            = image_tag @user.profile_image
          - else
            %img{:src => "/assets/images/user.svg", :alt => "user default logo"}
        - if @user.profile_image
          = link_to "Remove profile image", delete_profile_image_path(username: @user.username), method: :delete, class: 'rails_editable-input button small', id: "remove_link"
        = f.file_field(:image, class: 'rails_editable-input')
        = f.text_field(:image_file_link, class: 'rails_editable-input', placeholder: t("user_profiles.image_link_placeholder"), size: "30")

    #profile_right
      .header
        #user_name
          %p
            User: #{@user.username}
        - if current_user == @user
          #edit_profile
            .controls
              %button.button.rails_editable-edit
                = t('editable.edit_details')

      #details
        #details_left
          .rails_editable-field
            #user_bio
              %p.rails_editable-content
                = preserve @user&.user_profile&.bio
              = f.text_area(:bio, class: 'rails_editable-input', placeholder: t("user_profiles.bio_placeholder"))

        #details_right

          .section.info-pill{class: ('has-content' if @user.email.present? && (current_user == @user || current_user&.admin?))}
            #user_email
              - if current_user == @user || current_user&.admin?
                - if @user.email.present?
                  #icon
                    %p &#x2709;
                .rails_editable-field
                  - if @user.email.present?
                    %p.rails_editable-content
                      = @user.email
                  = text_area(:email, :email, class: 'rails_editable-input', placeholder: t("users.useremail_placeholder"))

          .section.info-pill{class: ('has-content' if @user&.user_profile&.location.present? || current_user == @user)}
            #user_location
              - if @user&.user_profile&.location.present?
                #icon
                  %img{:src => "/assets/images/location.svg", :alt => "location logo"}
              .rails_editable-field
                - if @user&.user_profile&.location.present?
                  %p.rails_editable-content
                    = @user.user_profile.location
                = f.text_area(:location, class: 'rails_editable-input', placeholder: t("user_profiles.location_placeholder"))

          .section.info-pill{class: ('has-content' if @user&.user_profile&.institution.present? || current_user == @user)}
            #user_institution
              - if @user&.user_profile&.institution.present?
                #icon
                  %img{:src => "/assets/images/institution.svg", :alt => "institution logo"}
              .rails_editable-field
                - if @user&.user_profile&.institution.present?
                  %p.rails_editable-content
                    = @user.user_profile.institution
                = f.text_area(:institution, class: 'rails_editable-input', placeholder:t("user_profiles.institution_placeholder"))

          .section.info-pill{class: ('has-content' if @last_courses_user)}
            #profile_user_contributions
              - if @last_courses_user
                %p
                  %i.icon.icon-z-external-link_white
                  = contribution_link(@last_courses_user, 'Contributions', 'contribution_link')

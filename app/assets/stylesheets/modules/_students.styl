// The "Words Added" / "Characters Added" column headers contain a
// parenthetical disclaimer "(article | user | draft)" after a <br>
// tag. With no white-space constraint, narrow columns at high
// browser zoom break each token onto its own line ("(article", "|
// user", "|", "draft)"), producing a 5-line header. Forcing nowrap
// on the .users table headers keeps each line of the label intact;
// the <br> still produces the intended primary/disclaimer line
// break, and any overflow falls into the page's horizontal scroll
// which is acceptable for WCAG 1.4.4.
.users.table thead th
  white-space nowrap

.redlink
  color $warning_text

.sandbox-link
  font-size: 80%

.users-control
  text-align right

.students, .students-exercise
  .completeness
    display block
    font-size 0.8rem
  .modules-complete
    color $text

.users-articles
  align-items flex-start
  display flex
  width 100%
  aside.student-selection
    border-bottom 1px solid #DDDDDD
    border-top 1px solid #DDDDDD
    flex 1
    overflow hidden scroll
    margin-top 5px
    max-height 60vh
    ul
      list-style none
      li.student
        background white
        border 1px solid #DDDDDD
        border-right none
        margin 5px 0
        padding 15px
        &:first-child
          border-top none
          margin-top 0
        &:last-child
          border-bottom none
          margin-bottom 0
        &.selected
          background #676eb4
          color white
        p
          margin-bottom 0
        .real-name
          font-weight bold
  article.student-details
    flex 4
    padding 5px 0px 5px 30px
    section.assignments
      h4
        color #6A6A6A
      p.assignment-links
        margin-bottom 3px
    .no-selected-student
      background #EEEEEE
      border 1px solid #DDDDDD
      display flex
      flex-direction column
      padding 45px 15px
      text-align center
      h4
        margin-bottom 5px
  article.assignments-list
    .article-title, .current-status, .assignment-links
      font-size 12px
    aside.header
      display flex
      flex-direction row
      h3
        flex 1
        font-size 18px
        margin 10px 0 5px
      .button-actions
        flex 2
        text-align right
    .no-assignments
      font-size 14px
      padding 30px 30px 0
    h4.assignments-list-title
      margin 30px 0 0
    .current-status span
      color #676eb4
      font-weight bold
      padding 3px
    tr.article-row
      .article-title
        max-width 200px
        overflow-wrap anywhere
      &:hover
        cursor default
.sort-select.users
  display inline-block
  float none
  margin 0 10px
  position static

// ─── Community status badges (RevisionStatus.jsx) ────────────────────────────
.revision-status
  display inline-block
  font-size 0.75rem
  font-weight 600
  letter-spacing 0.02em
  padding 2px 8px
  border-radius 2px
  white-space nowrap
  cursor default

  &--accepted
    background-color #676EB4
    color #ffffff
    border 1px solid #676EB4

  &--reverted
    background-color #f8f9fa
    color #54595d
    border 1px solid #a2a9b1

  &--pending
    background-color #eef0f8
    color #3d4484
    border 1px solid #676EB4

// ─── Revision rows in the expanded drawer ────────────────────────────────────
.revision-row--reverted
  border-left 3px solid #a2a9b1
  background-color rgba(162, 169, 177, 0.08)
  td:first-child
    padding-left 8px

// ─── Contribution status badges ──────────────────────────────────────────────
.contribution-status
  display inline-block
  padding 2px 8px
  border-radius 10px
  font-size 0.78em
  font-weight 600
  white-space nowrap

.contribution-status--reverted
  background-color #f8f9fa
  color #54595d
  border 1px solid #a2a9b1

.contribution-status--under-review
  background-color #eef0f8
  color #3d4484
  border 1px solid #676EB4

.contribution-status--reviewed
  background-color #676EB4
  color #ffffff
  border 1px solid #676EB4

.contribution-status--not-accepted
  background-color #f8f9fa
  color #54595d
  border 1px solid #a2a9b1

.contribution-status--accepted
  background-color #676EB4
  color #ffffff
  border 1px solid #676EB4

// ─── Review progress bar ─────────────────────────────────────────────────────
.review-progress
  margin-top 4px

.review-progress__bar-track
  background-color #e0e0e0
  border-radius 4px
  height 6px
  width 100%
  overflow hidden
  display flex

.review-progress__bar-fill
  height 100%
  transition width 0.3s ease

.review-progress__bar-fill--accepted
  background-color #676EB4
  border-radius 4px 0 0 4px

.review-progress__bar-fill--invalidated
  background-color #54595d
  border-radius 0 4px 4px 0

.review-progress__label
  font-size 0.72em
  color #888
  margin-top 2px

// ─── Review error banner ──────────────────────────────────────────────────────
// Shown when validate/invalidate/clear fails (network error, session expired)
.contributions-review-error
  display flex
  align-items center
  justify-content space-between
  background-color #fef3cd
  color #54595d
  border 1px solid #676EB4
  border-left 4px solid #676EB4
  border-radius 2px
  padding 8px 12px
  margin-bottom 8px
  font-size 0.875rem

.contributions-review-error__close
  background none
  border none
  cursor pointer
  font-size 1rem
  color #54595d
  margin-left 12px
  padding 0
  line-height 1

  &:hover
    color #202122

// ─── Contributions paginator ─────────────────────────────────────────────────
.contributions-paginator
  display flex
  align-items center
  justify-content center
  gap 8px
  padding 8px 0 4px

.contributions-paginator__btn
  background none
  border 1px solid #a2a9b1
  border-radius 2px
  color #3366cc
  cursor pointer
  font-size 1.2rem
  line-height 1
  padding 2px 8px

  &:hover:not(:disabled)
    background-color #eef0f8
    border-color #676EB4

  &:disabled
    color #a2a9b1
    cursor default

.contributions-paginator__info
  font-size 0.8rem
  color #54595d

// ─── Evaluation column chips ──────────────────────────────────────────────────
// Three states: Validated (blue) | Invalidated (dark grey) | Pending review (light grey)
// Palette: dashboard brand_primary #676EB4, greys — no green/red
// Status column: shows the eval chip (instructor decision)
// Evaluation column: shows the diff +/- button

// ─── Column alignment — outer student list (StudentRevisionRow) ──────────────
// list.jsx generates th class from the key name (e.g. th.recent_revisions)
// td gets .col-center manually for symmetry with its header

th.recent_revisions,
th.character_sum_ms,
th.references_count,
th.total_uploads,
th.review_status
  text-align center !important

td.col-center
  text-align center
  vertical-align middle

td.col-review-status
  min-width 140px

// ─── Column alignment — inner contributions table (RevisionRow) ───────────────
.contributions-th--center
  text-align center !important

.contributions-th--status,
.contributions-th--evaluation
  text-align center !important
  padding-left 8px
  padding-right 8px

.contributions-td--center
  text-align center
  vertical-align middle

.revision-row__status-cell,
.revision-row__eval-cell
  vertical-align middle
  text-align center
  padding-left 8px
  padding-right 8px

.revision-row__status-inner
  display flex
  justify-content center
  align-items center
  width 100%

.eval-chip
  display inline-flex
  align-items center
  justify-content center
  font-size 0.75rem
  font-weight 600
  letter-spacing 0.02em
  padding 3px 10px
  border-radius 2px
  white-space nowrap
  cursor default

.eval-chip--validated
  background-color #676EB4
  color #ffffff
  border 1px solid #676EB4

.eval-chip--invalidated
  background-color #54595d
  color #ffffff
  border 1px solid #54595d

.eval-chip--pending
  background-color #eef0f8
  color #3d4484
  border 1px solid #676EB4

// Reverted by community wiki — muted palette, strikethrough
.eval-chip--reverted
  background-color #f8f9fa
  color #54595d
  border 1px solid #a2a9b1
  text-decoration line-through
  opacity 0.85

// Group: stacks wiki-status chip + instructor chip vertically
.eval-chip-group
  display flex
  flex-direction column
  align-items center
  gap 4px

// ─────────────────────────────────────────────────────────────────────────────


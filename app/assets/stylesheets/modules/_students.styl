// The "Words Added" / "Characters Added" column headers contain a
// parenthetical disclaimer "(article | user | draft)" after a <br>
// tag. With no white-space constraint, narrow columns at high
// browser zoom break each token onto its own line ("(article", "|
// user", "|", "draft)"), producing a 5-line header. Forcing nowrap
// on the .users table headers keeps each line of the label intact;
// the <br> still produces the intended primary/disclaimer line
// break, and any overflow falls into the page's horizontal scroll
// which is acceptable for WCAG 1.4.4.
.users.table thead th
  white-space nowrap

.redlink
  color $warning_text

.sandbox-link
  font-size: 80%

.users-control
  text-align right

.students, .students-exercise
  .completeness
    display block
    font-size 0.8rem
  .modules-complete
    color $text

.users-articles
  align-items flex-start
  display flex
  width 100%
  aside.student-selection
    border-bottom 1px solid #DDDDDD
    border-top 1px solid #DDDDDD
    flex 1
    overflow hidden scroll
    margin-top 5px
    max-height 60vh
    ul
      list-style none
      li.student
        background white
        border 1px solid #DDDDDD
        border-right none
        margin 5px 0
        padding 15px
        &:first-child
          border-top none
          margin-top 0
        &:last-child
          border-bottom none
          margin-bottom 0
        &.selected
          background #676eb4
          color white
        p
          margin-bottom 0
        .real-name
          font-weight bold
  article.student-details
    flex 4
    padding 5px 0px 5px 30px
    section.assignments
      h4
        color #6A6A6A
      p.assignment-links
        margin-bottom 3px
    .no-selected-student
      background #EEEEEE
      border 1px solid #DDDDDD
      display flex
      flex-direction column
      padding 45px 15px
      text-align center
      h4
        margin-bottom 5px
  article.assignments-list
    .article-title, .current-status, .assignment-links
      font-size 12px
    aside.header
      display flex
      flex-direction row
      h3
        flex 1
        font-size 18px
        margin 10px 0 5px
      .button-actions
        flex 2
        text-align right
    .no-assignments
      font-size 14px
      padding 30px 30px 0
    h4.assignments-list-title
      margin 30px 0 0
    .current-status span
      color #676eb4
      font-weight bold
      padding 3px
    tr.article-row
      .article-title
        max-width 200px
        overflow-wrap anywhere
      &:hover
        cursor default
.sort-select.users
  display inline-block
  float none
  margin 0 10px
  position static

// ─── Revision quality status badges ──────────────────────────────────────────
.revision-status
  display inline-block
  font-size 0.75rem
  font-weight 600
  letter-spacing 0.02em
  padding 2px 8px
  border-radius 999px
  white-space nowrap
  cursor default

  &--accepted
    background-color #d4edda
    color #155724
    border 1px solid #c3e6cb

  &--reverted
    background-color #f8d7da
    color #721c24
    border 1px solid #f5c6cb

  &--pending
    background-color #fff3cd
    color #856404
    border 1px solid #ffc107

// Center the community_status column header to match the centered td content.
// Higher specificity (0,2,2) than the global .table thead tr th rule (0,1,3).
.table thead th.community_status
  text-align center

// ─── Community status cell (collapsed student row) ───────────────────────────
// Primary: large bold percentage, secondary: small accepted✓ · reverted✗ counts
.community-status-cell
  cursor default

.community-status-score
  font-size 1.1rem
  font-weight 800
  line-height 1.1
  letter-spacing -0.01em
  text-align center
  width 100%

.community-status-counts
  font-size 0.72rem
  margin-top 3px
  white-space nowrap
  color #555
  text-align center
  width 100%

  .count-accepted
    color #155724
    font-weight 600

  .count-reverted
    color #721c24
    font-weight 600

// ─── Revision rows in the expanded drawer ────────────────────────────────────
.revision-row--reverted
  border-left 3px solid #dc3545
  background-color rgba(220, 53, 69, 0.05)
  td:first-child
    padding-left 8px

// ─── Contribution status badges ──────────────────────────────────────────────
.contribution-status
  display inline-block
  padding 2px 8px
  border-radius 10px
  font-size 0.78em
  font-weight 600
  white-space nowrap

.contribution-status--reverted
  background-color #fce8e8
  color #c0392b
  border 1px solid #e8a0a0

.contribution-status--under-review
  background-color #fff8e1
  color #b7770d
  border 1px solid #f0d080

.contribution-status--not-accepted
  background-color #f0f0f0
  color #666
  border 1px solid #ccc

.contribution-status--accepted
  background-color #e8f8f0
  color #1a7a4a
  border 1px solid #80d4a8

// ─── Accept button inside the revision drawer ────────────────────────────────
.contribution-status-action
  margin-top 4px

.accept-contributions-btn
  font-size 0.75em
  padding 2px 8px

.unaccept-contributions-btn
  font-size 0.75em
  padding 2px 8px


.campaign-path
  .campaign_main
    .Select
      top 10px

    .rails_editable-input
      display: none

  .button.dark.green,
  input.button.dark
    background-color sprout
    border-color sprout

  .campaign-details
    .form-group > label
      display: inline

    .button.plus
      display: none

  .campaign-details.rails_editable-editing
    label
      display: block

  .campaign-delete
    margin-top: 20px
    text-align: center
    button
      width: 80%

  .campaign-create
    margin-bottom: 20px
    margin-top: 20px
    text-align: center
    button
      width: 80%

  .campaign-organizers
    display: inline-block

  #edit_campaign_details
    .form-group
      margin-bottom: 0

    .campaign-use-dates
      display: none

      input
        width: auto

  .rails_editable-editing #edit_campaign_details
    .form-group
      margin-bottom: 8px

    .campaign-use-dates
      display: block

  .create-campaign-button
    margin-bottom: 50px

  .wizard .right
    width: 100% !important

  .campaign-template-description
    .tooltip
      color: white
      font-size: 12px
      min-width: 250px

  .campaign-new
    span
      display block
      margin-top 4px
      font-weight 600

// ── Wikidata Tags Widget ─────────────────────────────────────────────────────

.wikidata-tags-widget
  position relative
  width 100%

.wikidata-tags-chips
  display flex
  flex-wrap wrap
  gap 6px
  margin-bottom 6px
  min-height 4px

.wikidata-tags-chip
  display inline-flex
  align-items center
  gap 4px
  background-color $bg_light_gray
  border 1px solid border_lt
  border-radius 3px
  padding 3px 6px
  font-size 12px

  &__link
    color sprout
    text-decoration none
    display inline-flex
    align-items center
    gap 4px
    &:hover
      text-decoration underline

  &__qnum
    color dove
    font-size 10px
    font-weight normal

  &__remove
    background none
    border none
    color dove
    cursor pointer
    font-size 12px
    line-height 1
    padding 0 2px
    &:hover
      color $warning_text

.wikidata-tags-input-row
  display flex
  align-items center
  gap 6px
  position relative

.wikidata-tags-search
  flex 1
  border 1px solid border_lt
  border-radius 3px
  font-size 13px
  padding 5px 8px
  width 100%
  &:focus
    border-color sprout
    outline none

.wikidata-tags-spinner
  width 14px
  height 14px
  border 2px solid border_lt
  border-top-color sprout
  border-radius 50%
  animation wikidata-spin 0.7s linear infinite
  flex-shrink 0
  &.hidden
    display none

@keyframes wikidata-spin
  to
    transform rotate(360deg)

.wikidata-tags-dropdown
  position absolute
  top 100%
  left 0
  right 0
  z-index 200
  background white
  border 1px solid border_lt
  border-radius 3px
  box-shadow 0 2px 8px rgba(0,0,0,0.12)
  list-style none
  margin 2px 0 0
  max-height 220px
  overflow-y auto
  padding 0
  &.hidden
    display none

.wikidata-tags-option
  cursor pointer
  padding 7px 10px
  display flex
  flex-wrap wrap
  align-items baseline
  gap 4px
  border-bottom 1px solid $bg_light_gray
  &:last-child
    border-bottom none
  &:hover
    background-color $bg_light_gray

  &__label
    font-size 13px
    font-weight 600
    color #222

  &__id
    font-size 11px
    color dove

  &__desc
    font-size 11px
    color #666
    width 100%

// ── End Wikidata Tags Widget ──────────────────────────────────────────────────

// ── Campaign Tags Page ────────────────────────────────────────────────────────

.campaign-tags-page
  padding 30px 0

  .campaign-tags-header
    margin-bottom 24px

    h2
      font-size 24px
      font-weight 700
      margin-bottom 8px
      color $brand_primary

    p
      color dove
      font-size 14px

  .campaign-tags-cloud
    display flex
    flex-wrap wrap
    gap 10px
    padding 20px
    background-color $bg_light_gray
    border-radius 0
    min-height 80px
    align-items center

    .campaign-tags-empty
      color dove
      font-style italic
      font-size 14px

  .campaign-tag-chip
    display inline-flex
    align-items center
    gap 5px
    background-color $bg_light_gray
    border 1px solid border_lt
    border-radius 0
    padding 4px 8px
    font-size 12px
    font-weight 400
    transition border-color 0.12s ease

    &:hover
      border-color $brand_primary

    a
      color $text_dk
      text-decoration none
      display inline-flex
      align-items center
      gap 5px

      &:hover
        color $brand_primary

    .campaign-tag-chip__qnum
      color dove
      font-size 10px
      font-weight normal

    .campaign-tag-chip__desc
      font-size 11px
      color dove
      display block
      margin-top 2px

    .campaign-tag-chip__badge
      display inline-block
      font-size 9px
      font-weight 700
      border-radius 4px
      padding 1px 5px
      text-transform uppercase
      letter-spacing 0.3px
      line-height 1.4

    .campaign-tag-chip__badge--campaign
      background-color #dbeafe
      color #1d4ed8

    .campaign-tag-chip__badge--course
      background-color #dcfce7
      color #15803d

    .campaign-tag-chip__badge--both
      background-color #fef9c3
      color #854d0e

// ── Campaign Tags Page – extra sections ──────────────────────────────────────

.campaign-tags-cloud-section
  margin-bottom 32px

  h3
    font-size 16px
    font-weight 600
    margin-bottom 14px
    color #333

// ── Summary stats strip ───────────────────────────────────────────────────────

.campaign-tags-summary
  display flex
  gap 24px
  margin-bottom 28px
  flex-wrap wrap

  &__item
    background-color white
    border 1px solid border_lt
    border-radius 0
    padding 24px 28px
    display flex
    flex-direction column
    align-items center
    justify-content center
    min-width 140px
    min-height 140px
    box-shadow none
    color $text_dk
    margin-top 0
    text-align center

  &__number
    font-size 42px
    font-weight 800
    color $brand_primary
    line-height 1

  &__label
    margin-top 8px
    font-size 12px
    letter-spacing 0.02em
    text-transform uppercase
    color $text_dk
.campaign-tags-filter-dropdown
  position relative
  display inline-block

.campaign-tags-filter-toggle
  display inline-flex
  align-items center
  gap 8px
  background white
  border 1px solid $brand_primary
  border-radius 0
  padding 10px 18px
  font-size 14px
  font-weight 700
  color $brand_primary
  cursor pointer
  transition border-color 0.12s ease, background 0.12s ease, box-shadow 0.12s ease
  z-index 5

  &:hover
    border-color $brand_primary
    background rgba($brand_primary, 0.08)
    box-shadow 0 4px 12px rgba($brand_primary, 0.12)

  &.active
    background $brand_primary
    color white
    border-color $brand_primary

.campaign-tags-filter-count
  display none
  align-items center
  justify-content center
  min-width 18px
  height 18px
  padding 0 5px
  border-radius 0

.campaign-tags-filter-panel
  position absolute
  top calc(100% + 6px)
  left 0
  z-index 20
  width 360px
  max-width 90vw
  background white
  border 1px solid border_lt
  border-radius 0
  box-shadow 0 8px 20px rgba(0,0,0,0.08)
  max-height 320px
  overflow hidden
  padding 8px 0

.campaign-tags-filter-options
  display flex
  flex-direction column
  gap 4px
  padding: 0 8px
  max-height 240px
  overflow-y auto

.campaign-tags-filter-option
  display flex
  align-items center
  gap 10px
  padding 8px 10px
  border-radius 0
  cursor pointer
  font-size 13px
  color $text_dk
  background white
  border-bottom 1px solid $border_lt

  &:hover
    background $bg_light_gray

  input[type='checkbox']
    accent-color $brand_primary
    cursor pointer
    width 16px
    height 16px

  &__name
    flex 1
    word-break break-word

  &__count
    color dove
    font-size 11px
    margin-left auto

.campaign-tags-filter-option:last-child
  border-bottom none

.campaign-tags-filter-loading
  color dove
  font-style italic
  font-size 13px
  padding 8px

.campaign-tags-filter-actions
  display flex
  justify-content space-between
  gap 8px
  margin-top 8px
  padding: 10px 8px 8px
  align-items center
  border-top 1px solid $border_lt

.campaign-tags-filter-clear
  display inline-flex
  align-items center
  justify-content center
  min-width 70px
  background $bg_light_gray
  border 1px solid border_lt
  color $text_dk
  font-size 12px
  font-weight 600
  padding 7px 12px
  cursor pointer
  text-decoration none
  transition background 0.12s ease, border-color 0.12s ease, color 0.12s ease

  &:hover
    background rgba($brand_primary, 0.08)
    border-color $brand_primary
    color $brand_primary

.campaign-tags-filter-apply
  background white
  border 1px solid $brand_primary
  border-radius 0
  color $brand_primary
  font-weight 700
  padding 7px 16px
  cursor pointer
  transition background 0.12s ease, color 0.12s ease, border-color 0.12s ease

  &:hover
    background rgba($brand_primary, 0.08)

.campaign-tags-filter-table-wrapper
  overflow-x auto
  border 1px solid border_lt
  border-radius 0
  font-size 13px

  .campaign-tags-filter-table
    width 100%
    border-collapse collapse
    border-spacing 0
    background white

    th,
    td
      padding 8px 10px
      border-right 1px solid border_lt

    th:last-child,
    td:last-child
      border-right none

    th
      text-align left
      background $bg_light_gray
      color $text_dk
      font-weight 600
      font-size 12px
      border-bottom 1px solid border_lt

    td
      border-bottom 1px solid border_lt
      vertical-align top

    tr:last-child td
      border-bottom none

    tr:hover td
      background rgba(103,110,180,0.04)

    a
      color $brand_primary
      text-decoration none

      &:hover
        text-decoration underline

  .campaign-tags-filter-table-tags
    display flex
    flex-wrap wrap
    gap 8px

  .campaign-tags-filter-chip
    display inline-flex
    align-items center
    padding 4px 9px
    background rgba(103,110,180,0.12)
    color $brand_primary
    font-size 11px
    font-weight 600
    border 1px solid rgba($brand_primary, 0.18)
    border-radius 0

    a
      color inherit
      text-decoration none

      &:hover
        text-decoration underline

.tags-charts-section
  margin-top 36px

  &.hidden
    display none

  h3
    font-size 22px
    font-weight 700
    margin-bottom 10px
    color $brand_primary

  .tags-charts-subtitle
    font-size 14px
    color dove
    margin-bottom 20px

// Tab switcher
.tags-chart-tabs
  display flex
  gap 4px
  margin-bottom 0
  border-bottom 2px solid border_lt
  flex-wrap wrap

.tags-chart-tab
  background none
  border none
  border-bottom 3px solid transparent
  margin-bottom -2px
  padding 8px 18px
  font-size 13px
  font-weight 500
  color dove
  cursor pointer
  transition color 0.15s, border-color 0.15s
  border-radius 4px 4px 0 0

  &:hover
    color #333
    background-color $bg_light_gray

  &.active
    color $brand_primary
    border-bottom-color $brand_primary
    font-weight 600

// Chart panels
.tags-chart-panel
  display none
  background white
  border 1px solid border_lt
  border-top none
  border-radius 0 0 6px 6px
  padding 24px

  &.active
    display block

.tags-chart-canvas-wrapper
  position relative
  height 360px
  width 100%

  &--doughnut
    height 380px

// Loading / empty states
.tags-charts-loading
  color dove
  font-style italic
  font-size 13px
  padding 20px 0
  text-align center

.tags-charts-empty
  color dove
  font-style italic
  font-size 14px
  padding 40px
  text-align center

// ── Custom chart tooltip ──────────────────────────────────────────────────────
// Colors derived from WikiEduDashboard design system:
//   $brand_primary #676EB4  ·  sprout #2A8270  ·  $action #1F6F95
//   $text_dk #2C2C2C  ·  border_lt #D9D9D9  ·  smoke #FAFAFA

#tags-chart-tooltip
  position absolute
  z-index 9999
  pointer-events none
  opacity 0
  transform translateY(4px) scale(0.98)
  transition opacity 0.16s ease, transform 0.16s ease
  min-width 224px
  max-width 316px
  background darken($brand_primary, 22%)
  color smoke
  border-radius 4px
  border 1px solid rgba($brand_primary, 0.35)
  box-shadow 0 10px 32px rgba(44,47,82,0.38), 0 2px 8px rgba(44,47,82,0.22)
  padding 13px 15px
  font-size 13px
  line-height 1.5
  &.visible
    opacity 1
    transform translateY(0) scale(1)
    pointer-events auto

  .tct-header
    display flex
    align-items center
    gap 8px
    margin-bottom 5px

  .tct-color-swatch
    flex-shrink 0
    width 11px
    height 11px
    border-radius 3px
    border 1px solid rgba(smoke,0.18)

  .tct-tag-name
    font-weight 700
    font-size 13.5px
    color smoke
    flex 1
    word-break break-word

  .tct-qid
    flex-shrink 0
    font-size 10px
    font-weight 600
    color smoke
    background rgba($brand_primary, 0.18)
    border-radius 3px
    padding 1px 6px
    text-decoration none
    letter-spacing 0.3px
    &:hover
      color smoke
      background rgba($brand_primary, 0.32)

  .tct-description
    font-size 11.5px
    color smoke
    font-style italic
    margin 0 0 7px
    line-height 1.4

  .tct-divider
    height 1px
    background rgba($brand_primary, 0.22)
    margin 7px 0

  .tct-section-label
    font-size 9.5px
    font-weight 700
    text-transform uppercase
    letter-spacing 0.9px
    color smoke
    margin 0 0 5px

  .tct-course-list
    list-style none
    margin 0 0 8px
    padding 0
    max-height 160px
    overflow-y auto
    scrollbar-width thin
    scrollbar-color rgba($brand_primary,0.3) transparent

  .tct-course-item
    display flex
    align-items baseline
    gap 7px
    padding 3px 0
    border-bottom 1px solid rgba($brand_primary, 0.12)
    &:last-child
      border-bottom none

  .tct-course-dot
    flex-shrink 0
    width 5px
    height 5px
    border-radius 50%
    background $brand_primary
    margin-top 2px

  .tct-course-link
    color smoke
    text-decoration none
    font-size 12.5px
    line-height 1.4
    word-break break-word
    &:hover
      color smoke
      text-decoration underline

  .tct-course-none
    color smoke
    font-style italic
    font-size 12px

  .tct-footer
    display flex
    align-items center
    justify-content space-between
    margin-top 6px

  .tct-count
    font-size 11px
    font-weight 700
    color smoke
    letter-spacing 0.2px

// ── End Custom chart tooltip ──────────────────────────────────────────────────

// ── End Campaign Tags Charts ──────────────────────────────────────────────────

// ── End Campaign Tags Page ────────────────────────────────────────────────────

.high-modal
  float right


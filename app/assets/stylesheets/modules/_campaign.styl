.campaign-path
  .campaign_main
    .Select
      top 10px

    .rails_editable-input
      display: none

  .button.dark.green,
  input.button.dark
    background-color sprout
    border-color sprout

  .campaign-details
    .form-group > label
      display: inline

    .button.plus
      display: none

  .campaign-details.rails_editable-editing
    label
      display: block

  .campaign-delete
    margin-top: 20px
    text-align: center
    button
      width: 80%

  .campaign-create
    margin-bottom: 20px
    margin-top: 20px
    text-align: center
    button
      width: 80%

  .campaign-organizers
    display: inline-block

  #edit_campaign_details
    .form-group
      margin-bottom: 0

    .campaign-use-dates
      display: none

      input
        width: auto

  .rails_editable-editing #edit_campaign_details
    .form-group
      margin-bottom: 8px

    .campaign-use-dates
      display: block

  .create-campaign-button
    margin-bottom: 50px

  .wizard .right
    width: 100% !important

  .campaign-template-description
    .tooltip
      color: white
      font-size: 12px
      min-width: 250px

  .campaign-new
    span
      display block
      margin-top 4px
      font-weight 600

// ── Wikidata Tags Widget ─────────────────────────────────────────────────────

.wikidata-tags-widget
  position relative
  width 100%

.wikidata-tags-chips
  display flex
  flex-wrap wrap
  gap 6px
  margin-bottom 6px
  min-height 4px

.wikidata-tags-chip
  display inline-flex
  align-items center
  gap 4px
  background-color $bg_light_gray
  border 1px solid border_lt
  border-radius 3px
  padding 3px 6px
  font-size 12px

  &__link
    color sprout
    text-decoration none
    display inline-flex
    align-items center
    gap 4px
    &:hover
      text-decoration underline

  &__qnum
    color dove
    font-size 10px
    font-weight normal

  &__remove
    background none
    border none
    color dove
    cursor pointer
    font-size 12px
    line-height 1
    padding 0 2px
    &:hover
      color $warning_text

.wikidata-tags-input-row
  display flex
  align-items center
  gap 6px
  position relative

.wikidata-tags-search
  flex 1
  border 1px solid border_lt
  border-radius 3px
  font-size 13px
  padding 5px 8px
  width 100%
  &:focus
    border-color sprout
    outline none

.wikidata-tags-spinner
  width 14px
  height 14px
  border 2px solid border_lt
  border-top-color sprout
  border-radius 50%
  animation wikidata-spin 0.7s linear infinite
  flex-shrink 0
  &.hidden
    display none

@keyframes wikidata-spin
  to
    transform rotate(360deg)

.wikidata-tags-dropdown
  position absolute
  top 100%
  left 0
  right 0
  z-index 200
  background white
  border 1px solid border_lt
  border-radius 3px
  box-shadow 0 2px 8px rgba(0,0,0,0.12)
  list-style none
  margin 2px 0 0
  max-height 220px
  overflow-y auto
  padding 0
  &.hidden
    display none

.wikidata-tags-option
  cursor pointer
  padding 7px 10px
  display flex
  flex-wrap wrap
  align-items baseline
  gap 4px
  border-bottom 1px solid $bg_light_gray
  &:last-child
    border-bottom none
  &:hover
    background-color $bg_light_gray

  &__label
    font-size 13px
    font-weight 600
    color #222

  &__id
    font-size 11px
    color dove

  &__desc
    font-size 11px
    color #666
    width 100%

// ── End Wikidata Tags Widget ──────────────────────────────────────────────────

.high-modal
  float right


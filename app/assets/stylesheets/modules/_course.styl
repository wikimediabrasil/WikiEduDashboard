.course_main,
.campaign_main
  margin-top 30px

  .stat-display
    margin-bottom 0px
    margin-top 0px

.course
  background #fff
  border 1px solid $border_lt
  padding 20px
  margin-bottom 20px
  display block
  text-decoration none
  color inherit
  position relative

  &:before
    content ""
    position absolute
    left 0
    right 0
    top 0
    bottom 0
    box-shadow 0px 2px 4px rgba(0,0,0,1)
    opacity .1
    transition all 125ms ease-in-out

  &:hover
    &:before
      opacity .3
      box-shadow 0px 2px 4px $brand_primary

  &.course-past
    .course-title
      color $text_med_header
      margin-bottom 0

    .button
      position relative
      top -4px
      border-color $text_med_header
      color $text_med_header

  + h2
    margin-top 60px

  .button
    float right

  &:hover
    .button
      background $brand_primary
      border-color $brand_primary
      color #fff

  .course-title
    font-weight 300
    font-size 30px
    margin-bottom 20px
    color bayoux
    line-height 1
    display flex
    align-items center

    .course-term
      color $text_med_header
      margin-left 100px
      margin-right 20px

    .new_or_returning
      font-size smaller
      padding-left 20px
      color $text_med_header

  .course-details
    display flex

    .col
      margin-right 40px
      &:first-child
        width: 300px
      &:nth-child(2)
        width: 150px
      &:nth-child(3)
        width: 100px
      &:last-child
        margin-right 0

    .course-details_title
      color $text_med_header

    .course-details_value
      font-size 19px
      color $text

.course-syllabus__uploader
  position relative
  background rgba($border_lt, .5)
  height 250px
  border 2px dashed $border_lt

  & > div
    position absolute
    top 50%
    left 50%
    width 100%
    text-align center
    padding 1em
    transform translate(-50%, -50%)

.course__syllabus-upload__inner
  width 80%
  max-width 800px

.avatar, .rating
  margin-left 15px
  margin-right 15px
  +above(desktop)
    display inline-block

.avatar
  round-placeholder(23)
  float left
  img
    width 46px

rating(color)
  border 3px solid color
  p
    color $text_dk

.statistics-update-info
  a
    color inherit

.statistics-update-modal-container
  display flex
  justify-content center
  align-items center

.statistics-update-modal
  background-color white
  box-shadow 0px 1px 6px rgba(0, 0, 0, 0.1)
  position absolute
  z-index 1
  padding 30px
  width 90%
  @media only screen and (min-width: 920px)
    width 700px
    margin-top 200px

.event-sync
  width 100%
  display inline-flex

.rating
  round-placeholder(23)
  rating(#D2D2D2)
  background-color transparent
  border 3px solid #D2D2D2
  text-align center
  text-transform uppercase
  float left
  p
    font-size 15px
    font-weight 600
    line-height 40px

  &.null
    rating(#D2D2D2)
  &.fa, &.fl
    rating(#E36944)
  &.a
    rating(#656E92)
  &.ga
    rating(#F9C623)
  &.b
    rating(#858DAA)
  &.c
    rating(#858DAA)
  &.start
    rating(#858DAA)
  &.stub
    rating(#D2D2D2)
  &.list
    rating(#656E92)

.modal-course-details
  display inline-block

  .wizard
    z-index 1

  .course-details
    width 90%
    top 60px
    max-width 920px

  .group-left,
  .group-right
    width 50%
    margin 20px
    text-align left

  .details-form,
  .course-approval-field
    display flex

@media only screen and (max-width: 919px)
  .campaign_main
    margin-top 163px

  .course
    padding 3px

    .course-title
      font-size 15px

    .course-details
      display inline-block

      .col
        display flex
        margin-right unset

      .course-details_title
        padding-right 5px
      .course-details_value
        font-size 15px

  .modal-course-details
    top 100px

    .group-left,
    .group-right
      width 90%
      margin 10px

    .details-form
      display block

.multi-wiki [class$='multiValue']:first-of-type svg
  display: none;

.multi-wiki input[readonly]
  display: none

.modal-course-details
    .pop__container
        form
          display flex
          align-items center
          justify-content center
        .pop
          form
            flex-direction  column
            input
              width 200px
              margin-bottom 10px

@media only screen and (min-width: 919px) and (max-width: 986px)
  .campaign_main
    margin-top 60px

// ── Wikidata Label Editable (course overview) ─────────────────────────────────

.wikidata-label-search-wrapper
  position relative
  min-width 260px

.wikidata-label-search-input
  width 100%
  padding 5px 8px
  border 1px solid border_lt
  border-radius 4px
  font-size 13px
  &:focus
    outline none
    border-color sprout

.wikidata-label-searching
  position absolute
  right 8px
  top 50%
  transform translateY(-50%)
  color dove
  font-size 12px

.wikidata-label-suggestions
  position absolute
  z-index 200
  background white
  border 1px solid border_lt
  border-radius 4px
  box-shadow 0 2px 8px rgba(0,0,0,0.12)
  list-style none
  margin 2px 0 0
  padding 0
  max-height 200px
  overflow-y auto
  width 100%

.wikidata-label-suggestion
  cursor pointer
  padding 7px 10px
  display flex
  flex-wrap wrap
  align-items baseline
  gap 4px
  border-bottom 1px solid $bg_light_gray
  &:last-child
    border-bottom none
  &:hover
    background-color $bg_light_gray

  &__label
    font-size 13px
    font-weight 600
    color #222

  &__id
    font-size 11px
    color dove

  &__desc
    font-size 11px
    color #666
    width 100%

.tag-qnum
  font-size 11px
  color dove

.wikidata-labels-list
  display block
  margin-top 4px
  a
    color sprout
    text-decoration none
    &:hover
      text-decoration underline

// ── End Wikidata Label Editable ───────────────────────────────────────────────

.course-tags-page
  width 100%
  max-width 1080px
  padding 34px 0 48px

.course-tags-header
  display flex
  align-items flex-end
  justify-content space-between
  gap 30px
  padding 24px 28px
  background white
  border-top 5px solid sprout
  border-bottom 1px solid border_lt

  h3
    color $text_dk
    font-size 28px
    font-weight 500
    line-height 1.15
    margin 5px 0 8px

  p
    color dove
    font-size 14px
    line-height 1.5
    margin 0
    max-width 650px

  &__eyebrow
    color sprout
    font-size 11px
    font-weight 700
    letter-spacing 1.4px
    text-transform uppercase

  &__total
    min-width 92px
    padding-left 22px
    border-left 1px solid border_lt
    display flex
    flex-direction column
    align-items flex-end

    strong
      color $brand_primary
      font-size 36px
      font-weight 600
      line-height 1

    span
      color dove
      font-size 11px
      letter-spacing 0.8px
      margin-top 4px
      text-transform uppercase

.course-tags-index
  background $bg_light_gray
  border-bottom 1px solid border_lt
  padding 0 28px 28px

  &__heading
    display flex
    justify-content space-between
    gap 20px
    padding 13px 0
    color dove
    font-size 10px
    font-weight 700
    letter-spacing 1px
    text-transform uppercase

    span:last-child
      max-width 60%
      overflow hidden
      text-overflow ellipsis
      white-space nowrap

.course-tags-gallery
  display grid
  grid-template-columns repeat(2, minmax(0, 1fr))
  gap 1px
  background border_lt
  border 1px solid border_lt

.course-tag-card
  min-height 138px
  display grid
  grid-template-columns 36px minmax(0, 1fr) auto
  gap 16px
  padding 20px
  background white
  color $text_dk
  text-decoration none
  border-left 4px solid $brand_primary
  transition background-color 0.15s ease, transform 0.15s ease

  &:hover, &:focus
    background lighten($brand_primary, 96%)
    color $text_dk
    outline none
    transform translateY(-2px)

    .course-tag-card__arrow
      transform translate(2px, -2px)

  &--2
    border-left-color sprout

    .course-tag-card__index
      color sprout

  &--3
    border-left-color $action

    .course-tag-card__index
      color $action

  &__index
    color $brand_primary
    font-size 12px
    font-weight 700
    letter-spacing 0.8px
    padding-top 3px

  &__content
    display flex
    flex-direction column
    min-width 0

  &__label
    color $text_dk
    font-size 18px
    font-weight 600
    line-height 1.25
    overflow-wrap anywhere

  &__description
    color dove
    display -webkit-box
    font-size 12px
    line-height 1.45
    margin-top 9px
    overflow hidden
    -webkit-box-orient vertical
    -webkit-line-clamp 3

  &__meta
    display flex
    align-items flex-start
    gap 8px

  &__qid
    color dove
    background $bg_light_gray
    border 1px solid border_lt
    font-family monospace
    font-size 10px
    padding 3px 6px

  &__arrow
    color $brand_primary
    font-size 16px
    line-height 1
    transition transform 0.15s ease

.course-tags-empty
  min-height 180px
  display flex
  align-items center
  justify-content center
  gap 14px
  background white
  border 1px solid border_lt
  color dove

  &__mark
    color lighten($brand_primary, 35%)
    font-size 42px
    font-weight 300

  p
    margin 0

.course-tags-admin
  display flex
  align-items center
  gap 12px
  padding 14px 28px
  border-bottom 1px solid border_lt
  background white
  color dove
  font-size 11px
  font-weight 700
  letter-spacing 0.8px
  text-transform uppercase

  .wikidata-labels
    margin 0

@media only screen and (max-width: 760px)
  .course-tags-page
    padding-top 20px

  .course-tags-header
    align-items flex-start
    padding 20px

    &__total
      min-width 66px
      padding-left 14px

  .course-tags-index
    padding 0 20px 20px

  .course-tags-gallery
    grid-template-columns 1fr

  .course-tag-card
    grid-template-columns 28px minmax(0, 1fr)

    &__meta
      grid-column 2
      justify-content space-between

// ── Wikidata tags in course creator ──────────────────────────────────────────

.course-creator-wikidata-tags
  margin-bottom 60px

  .text-input-component__label
    display block
    margin-bottom 6px

  .wikidata-tags-chips.creator
    display flex
    flex-wrap wrap
    gap 6px
    margin-bottom 8px

  .wikidata-tags-chip__remove
    background none
    border none
    cursor pointer
    color #999
    font-size 14px
    padding 0 2px
    margin-left 4px
    line-height 1
    &:hover
      color #e74c3c

// ── End Wikidata tags in course creator ──────────────────────────────────────
